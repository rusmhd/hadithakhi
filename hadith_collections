from sqlalchemy import Column, Integer, String, Text, Float, Boolean, JSON
from sqlalchemy.ext.declarative import declarative_base

Base = declarative_base()

class Hadith(Base):
    __tablename__ = "hadith"
    
    id = Column(Integer, primary_key=True, index=True)
    arabic_text = Column(Text)
    english_text = Column(Text, nullable=False)
    hadith_number = Column(String(50), unique=True, index=True)
    book = Column(String(100))
    chapter = Column(String(200))
    narrator = Column(String(200))
    themes = Column(String(500))  # Comma-separated themes
    embedding = Column(JSON)  # Store vector embedding as JSON
    authenticity_grade = Column(String(20))  # Sahih, Hasan, Daif, etc.
    source = Column(String(100))
    is_verified = Column(Boolean, default=True)

class MoodMapping(Base):
    __tablename__ = "mood_mappings"
    
    id = Column(Integer, primary_key=True, index=True)
    mood = Column(String(50), index=True)
    keywords = Column(Text)
    themes = Column(String(500))
    weight = Column(Float, default=1.0)

# Updated hadith_matcher.py - Enhanced matching with embeddings
import numpy as np
from sklearn.metrics.pairwise import cosine_similarity
from sentence_transformers import SentenceTransformer
from sqlalchemy.orm import Session
from app.models import Hadith, MoodMapping
from typing import List, Dict

class HadithMatcher:
    def __init__(self):
        self.model = SentenceTransformer('all-MiniLM-L6-v2')
        
    def find_by_mood(self, db: Session, mood: str, user_text: str = "", limit: int = 5) -> List[Dict]:
        """Find hadith based on mood and user context"""
        try:
            # Get user text embedding
            user_embedding = self.model.encode(user_text) if user_text else None
            
            # Query hadith with relevant themes
            mood_themes = self._get_mood_themes(mood)
            
            if mood_themes:
                # Search by themes first
                query = db.query(Hadith).filter(
                    Hadith.themes.contains(mood_themes[0])
                )
            else:
                # Fallback to all hadith
                query = db.query(Hadith)
            
            hadith_list = query.limit(50).all()  # Get larger set for similarity comparison
            
            if user_embedding is not None and hadith_list:
                # Calculate semantic similarity
                hadith_embeddings = []
                valid_hadith = []
                
                for hadith in hadith_list:
                    if hadith.embedding:
                        hadith_embeddings.append(hadith.embedding)
                        valid_hadith.append(hadith)
                
                if hadith_embeddings:
                    similarities = cosine_similarity([user_embedding], hadith_embeddings)[0]
                    
                    # Sort by similarity
                    sorted_indices = np.argsort(similarities)[::-1]
                    hadith_list = [valid_hadith[i] for i in sorted_indices[:limit]]
            else:
                hadith_list = hadith_list[:limit]
            
            return [self._format_hadith(hadith, mood) for hadith in hadith_list]
            
        except Exception as e:
            print(f"Error finding hadith by mood: {e}")
            return []
    
    def verify_hadith(self, db: Session, hadith_text: str) -> Dict:
        """Verify if a hadith exists in our authentic collection"""
        try:
            # Generate embedding for the input text
            input_embedding = self.model.encode(hadith_text)
            
            # Get all hadith embeddings
            hadith_list = db.query(Hadith).all()
            
            best_match = None
            best_similarity = 0
            
            for hadith in hadith_list:
                if hadith.embedding:
                    similarity = cosine_similarity([input_embedding], [hadith.embedding])[0][0]
                    if similarity > best_similarity:
                        best_similarity = similarity
                        best_match = hadith
            
            # Threshold for considering it a match (adjust as needed)
            if best_similarity > 0.8:
                return {
                    "is_authentic": True,
                    "confidence": float(best_similarity),
                    "matched_hadith": self._format_hadith(best_match),
                    "source": best_match.source,
                    "grade": best_match.authenticity_grade
                }
            else:
                return {
                    "is_authentic": False,
                    "confidence": float(best_similarity),
                    "message": "This hadith was not found in our authentic collection",
                    "closest_match": self._format_hadith(best_match) if best_match else None
                }
                
        except Exception as e:
            print(f"Error verifying hadith: {e}")
            return {"is_authentic": False, "error": str(e)}
    
    def _get_mood_themes(self, mood: str) -> List[str]:
        """Map mood to relevant Islamic themes"""
        mood_theme_map = {
            "sad": ["comfort", "hope", "patience"],
            "anxious": ["peace", "trust", "guidance"],
            "angry": ["patience", "forgiveness", "wisdom"],
            "grateful": ["gratitude", "blessing"],
            "confused": ["guidance", "wisdom", "knowledge"],
            "hopeless": ["hope", "mercy", "faith"],
            "lonely": ["companionship", "love", "community"],
            "stressed": ["ease", "relief", "trust"],
            "happy": ["gratitude", "joy", "celebration"],
            "repentant": ["repentance", "forgiveness", "mercy"]
        }
        return mood_theme_map.get(mood.lower(), ["general"])
    
    def _format_hadith(self, hadith: Hadith, context_mood: str = "") -> Dict:
        """Format hadith for API response with contextual explanation"""
        return {
            "id": hadith.id,
            "arabic": hadith.arabic_text,
            "english": hadith.english_text,
            "hadith_number": hadith.hadith_number,
            "book": hadith.book,
            "chapter": hadith.chapter,
            "narrator": hadith.narrator,
            "source": hadith.source,
            "authenticity_grade": hadith.authenticity_grade,
            "themes": hadith.themes.split(',') if hadith.themes else [],
            "contextual_explanation": self._generate_contextual_explanation(hadith, context_mood)
        }
    
    def _generate_contextual_explanation(self, hadith: Hadith, mood: str) -> str:
        """Generate mood-specific explanation for the hadith"""
        if not mood:
            return "This hadith provides timeless Islamic wisdom and guidance."
        
        explanations = {
            "sad": "This hadith offers comfort and reminds us that Allah is always with us in difficult times.",
            "anxious": "This teaching provides peace and guidance, showing how to find tranquility through faith.",
            "angry": "This wisdom teaches patience and forgiveness, helping to transform anger into understanding.",
            "grateful": "This hadith helps us recognize and appreciate the countless blessings in our lives.",
            "confused": "This guidance illuminates the path forward when life seems unclear.",
            "hopeless": "This teaching reminds us that Allah's mercy is vast and hope is always possible."
        }
        
        return explanations.get(mood.lower(), 
                              "This hadith provides guidance relevant to your current spiritual state.")

