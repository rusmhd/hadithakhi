# data_loader.py - Load Sahih Bukhari JSON into database
import json
import os
from sqlalchemy.orm import Session
from app.database import SessionLocal, engine
from app.models import Base, Hadith
from sentence_transformers import SentenceTransformer
import numpy as np

class BukhariLoader:
    def __init__(self, json_file_path: str):
        self.json_file_path = json_file_path
        self.model = SentenceTransformer('all-MiniLM-L6-v2')
        
    def load_json_data(self):
        """Load Sahih Bukhari JSON file"""
        try:
            with open(self.json_file_path, 'r', encoding='utf-8') as file:
                data = json.load(file)
            print(f"✅ Successfully loaded JSON with {len(data)} entries")
            return data
        except Exception as e:
            print(f"❌ Error loading JSON: {e}")
            return None
    
    def extract_mood_themes(self, text: str) -> str:
        """Extract potential mood themes from hadith text"""
        # Common Islamic themes and their mood associations
        theme_keywords = {
            'patience': ['patience', 'sabr', 'endure', 'persevere', 'trial', 'test'],
            'gratitude': ['grateful', 'thank', 'blessing', 'favor', 'appreciate'],
            'hope': ['hope', 'mercy', 'forgiveness', 'paradise', 'reward'],
            'guidance': ['guidance', 'path', 'right', 'guidance', 'knowledge'],
            'comfort': ['comfort', 'ease', 'relief', 'peace', 'calm'],
            'strength': ['strength', 'courage', 'brave', 'strong', 'overcome'],
            'wisdom': ['wisdom', 'knowledge', 'learn', 'understand', 'wise'],
            'compassion': ['compassion', 'mercy', 'kind', 'gentle', 'love'],
            'faith': ['faith', 'belief', 'trust', 'Allah', 'prayer'],
            'repentance': ['repent', 'forgive', 'sin', 'mistake', 'turn back']
        }
        
        text_lower = text.lower()
        detected_themes = []
        
        for theme, keywords in theme_keywords.items():
            if any(keyword in text_lower for keyword in keywords):
                detected_themes.append(theme)
        
        return ','.join(detected_themes) if detected_themes else 'general'
    
    def process_hadith_entry(self, entry, book_number: int = 1) -> dict:
        """Process individual hadith entry from JSON"""
        try:
            # Handle different JSON structures
            hadith_data = {}
            
            # Extract text (try different possible keys)
            text_keys = ['text', 'hadith', 'english', 'translation', 'content']
            for key in text_keys:
                if key in entry and entry[key]:
                    hadith_data['english_text'] = entry[key]
                    break
            
            # Extract Arabic text
            arabic_keys = ['arabic', 'arabic_text', 'original']
            for key in arabic_keys:
                if key in entry and entry[key]:
                    hadith_data['arabic_text'] = entry[key]
                    break
            
            # Extract hadith number
            number_keys = ['number', 'hadith_number', 'id', 'hadithNumber']
            for key in number_keys:
                if key in entry and entry[key]:
                    hadith_data['hadith_number'] = str(entry[key])
                    break
            
            # Extract narrator/chain
            narrator_keys = ['narrator', 'chain', 'isnad', 'narrated_by']
            for key in narrator_keys:
                if key in entry and entry[key]:
                    hadith_data['narrator'] = entry[key]
                    break
            
            # Extract book/chapter info
            if 'book' in entry:
                hadith_data['book'] = entry['book']
            if 'chapter' in entry:
                hadith_data['chapter'] = entry['chapter']
            
            # Set defaults
            hadith_data.setdefault('english_text', 'No English translation available')
            hadith_data.setdefault('arabic_text', '')
            hadith_data.setdefault('hadith_number', f"B{book_number}-{len(hadith_data)}")
            hadith_data.setdefault('narrator', 'Unknown')
            hadith_data.setdefault('book', 'Sahih Bukhari')
            hadith_data.setdefault('chapter', 'General')
            
            return hadith_data
        except Exception as e:
            print(f"❌ Error processing hadith entry: {e}")
            return None
    
    def load_to_database(self):
        """Load Sahih Bukhari data into database"""
        # Create tables
        Base.metadata.create_all(bind=engine)
        
        # Load JSON data
        json_data = self.load_json_data()
        if not json_data:
            return False
        
        db = SessionLocal()
        loaded_count = 0
        
        try:
            # Handle different JSON structures
            hadith_entries = []
            
            # If it's a list of hadith
            if isinstance(json_data, list):
                hadith_entries = json_data
            # If it's nested (books -> hadith)
            elif isinstance(json_data, dict):
                for book_key, book_data in json_data.items():
                    if isinstance(book_data, list):
                        hadith_entries.extend(book_data)
                    elif isinstance(book_data, dict) and 'hadith' in book_data:
                        hadith_entries.extend(book_data['hadith'])
            
            print(f"📚 Processing {len(hadith_entries)} hadith entries...")
            
            for i, entry in enumerate(hadith_entries):
                hadith_data = self.process_hadith_entry(entry, i + 1)
                
                if hadith_data and hadith_data['english_text'] != 'No English translation available':
                    # Generate embedding for semantic search
                    embedding = self.model.encode(hadith_data['english_text'])
                    
                    # Extract themes for mood matching
                    themes = self.extract_mood_themes(hadith_data['english_text'])
                    
                    # Create hadith object
                    hadith = Hadith(
                        arabic_text=hadith_data['arabic_text'],
                        english_text=hadith_data['english_text'],
                        hadith_number=hadith_data['hadith_number'],
                        book=hadith_data['book'],
                        chapter=hadith_data['chapter'],
                        narrator=hadith_data['narrator'],
                        themes=themes,
                        embedding=embedding.tolist(),
                        authenticity_grade="Sahih",  # All Bukhari hadith are Sahih
                        source="Sahih Bukhari"
                    )
                    
                    db.add(hadith)
                    loaded_count += 1
                    
                    if loaded_count % 100 == 0:
                        print(f"✅ Loaded {loaded_count} hadith...")
                        db.commit()
            
            db.commit()
            print(f"🎉 Successfully loaded {loaded_count} hadith from Sahih Bukhari!")
            return True
            
        except Exception as e:
            print(f"❌ Error loading to database: {e}")
            db.rollback()
            return False
        finally:
            db.close()

